# Community AI Monitor — Variables de entorno (desarrollo local)
# Copiar a .env y ajustar valores. El archivo .env NO debe subirse al repositorio.

# --- Backend (FastAPI) ---
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
BACKEND_PORT=8000
SEED_DEMO_DATA=true

# --- Simulador de cámara (FASE 4) ---
CAMERA_SIMULATOR_ENABLED=true
# Inicia workers al arrancar el backend. Desactivar si las cámaras RTSP no están listas.
CAMERA_SIMULATOR_AUTO_START=false
CAMERA_SIMULATOR_FPS=2
# Tiempo máximo de espera al detener un worker (eliminar cámara / apagar backend)
CAMERA_WORKER_SHUTDOWN_TIMEOUT_SECONDS=5
# Ruta opcional a un MP4 local (file:// también soportado en stream_url)
# CAMERA_SIMULATOR_VIDEO_PATH=/path/to/video.mp4
# Vista previa en vivo (solo memoria, no se guarda en BD)
CAMERA_PREVIEW_ENABLED=true
CAMERA_PREVIEW_FPS=2
CAMERA_PREVIEW_MAX_WIDTH=640
CAMERA_PREVIEW_JPEG_QUALITY=75
CAMERA_PREVIEW_SHOW_DETECTIONS=true

# --- Computer Vision / Detección (FASE 5) ---
# Requiere instalar requirements-ml.txt (YOLO). Si no está instalado,
# la detección se desactiva de forma segura.
DETECTION_ENABLED=true
DETECTION_MODEL=yolov8n.pt
DETECTION_CONFIDENCE=0.4
DETECTION_DEVICE=cpu
DETECTION_CLASSES=person,bicycle,car,motorcycle,bus,truck,dog,cat
DETECTION_INTERVAL_SECONDS=1.0
DETECTION_PERSIST_ENABLED=true
# Tracking temporal (IDs técnicos, no identidad persistente)
TRACKING_IOU_THRESHOLD=0.3
TRACKING_MAX_AGE=30

# --- Motor de eventos (FASE 6) ---
EVENT_ENGINE_ENABLED=true
EVENT_PERSIST_ENABLED=true
EVENT_COOLDOWN_SECONDS=60
# Conteo: personas > umbral
EVENT_CROWD_ENABLED=true
EVENT_CROWD_PEOPLE_THRESHOLD=5
# Aglomeración: densidad de área ocupada por personas
EVENT_HIGH_DENSITY_ENABLED=true
EVENT_HIGH_DENSITY_MIN_PEOPLE=3
EVENT_HIGH_DENSITY_THRESHOLD=0.15
# Permanencia: objeto visible > X segundos
EVENT_LONG_PRESENCE_ENABLED=true
EVENT_LONG_PRESENCE_SECONDS=300
EVENT_LONG_PRESENCE_CLASSES=person
# Objeto abandonado: sin movimiento > X segundos
EVENT_ABANDONED_OBJECT_ENABLED=true
EVENT_ABANDONED_DURATION_SECONDS=600
EVENT_ABANDONED_MOVEMENT_THRESHOLD=15
EVENT_ABANDONED_CLASSES=backpack,handbag,suitcase

# --- Motor de reglas comunitarias (Rule Engine) ---
RULE_ENGINE_ENABLED=true
RULE_SCENE_TYPE=general
RULE_EMIT_LEGACY_EVENT_TYPES=true
RULE_METRICS_ENABLED=true
# Personas
RULE_PERSON_LONG_STAY_ENABLED=true
RULE_PERSON_LONG_STAY_SECONDS=1200
RULE_PERSON_REPEATED_ACTIVITY_ENABLED=true
RULE_PERSON_REPEATED_ACTIVITY_WINDOW_SECONDS=1800
RULE_PERSON_REPEATED_ACTIVITY_MIN_VISITS=3
RULE_PERSON_REPEATED_ACTIVITY_ZONE_RADIUS=80
RULE_PERSON_HIDDEN_ACTIVITY_ENABLED=true
RULE_PERSON_HIDDEN_STAY_SECONDS=900
RULE_PERSON_HIDDEN_MAX_MOVEMENT=20
RULE_CROWD_THRESHOLD=15
# Vehículos
RULE_VEHICLE_LONG_PARKING_ENABLED=true
RULE_VEHICLE_PARKING_SECONDS=600
RULE_VEHICLE_PARKING_MOVEMENT_THRESHOLD=15
RULE_DOUBLE_PARKING_ENABLED=true
RULE_DOUBLE_PARKING_SECONDS=180
RULE_STREET_ZONE_Y_START=0.55
RULE_WRONG_DIRECTION_ENABLED=false
RULE_EXPECTED_TRAFFIC_DIRECTION=ltr
# Parque
RULE_PARK_OCCUPANCY_ENABLED=true
RULE_PARK_OCCUPANCY_CHANGE_THRESHOLD=5
RULE_PARK_EMPTY_ENABLED=true
RULE_PARK_EMPTY_SECONDS=1800
# Objetos / animales / placeholders
RULE_ABANDONED_OBJECT_SECONDS=900
RULE_ANIMAL_ENABLED=true
RULE_ANIMAL_CLASSES=dog,cat
RULE_ANIMAL_COOLDOWN_SECONDS=60
RULE_TRASH_DETECTED_ENABLED=false
RULE_OBSTRUCTION_DETECTED_ENABLED=false

# --- LLM / Resúmenes (FASE 7) ---
# Ollama local (gratis, sin API key): https://ollama.com
# Backend local:   http://localhost:11434
# Backend Docker:  http://host.docker.internal:11434
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.3
SUMMARY_MAX_EVENTS=200

# --- WebSocket tiempo real (FASE 9) ---
WEBSOCKET_ENABLED=true

# --- Cámaras IP / RTSP (FASE 11) ---
# tcp recomendado en producción (más estable que udp)
RTSP_TRANSPORT=tcp
RTSP_BUFFER_SIZE=1
RTSP_RECONNECT_DELAY_SECONDS=3
RTSP_READ_FAILURES_BEFORE_RECONNECT=3
RTSP_WARMUP_SECONDS=3
RTSP_TRANSPORT_FALLBACK=true
RTSP_PROBE_TIMEOUT_SECONDS=5
RTSP_USE_FFMPEG_FIRST=true
RTSP_FFMPEG_OUTPUT_MAX_WIDTH=640
RTSP_FFMPEG_READ_TIMEOUT_SECONDS=30
IP_WEBCAM_PREFER_HTTP=true

# --- PostgreSQL ---
POSTGRES_USER=cam_user
POSTGRES_PASSWORD=cam_dev_password
POSTGRES_DB=community_ai_monitor
POSTGRES_PORT=5432

# DATABASE_URL se construye automáticamente en Docker Compose.
# Para desarrollo local sin Docker:
# DATABASE_URL=postgresql://cam_user:cam_dev_password@localhost:5432/community_ai_monitor

# --- pgAdmin (opcional, profile "tools") ---
PGADMIN_EMAIL=admin@localhost.dev
PGADMIN_PASSWORD=cam_dev_password
PGADMIN_PORT=5050
